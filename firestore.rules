rules_version = '2';

// FitFamily — Firestore security rules.
//
// HONEST LIMITATION: the app authenticates with a per-user PIN, not Firebase
// Auth, so these rules cannot distinguish family members from each other.
// What they DO provide:
//   - Only the collections the app actually uses exist; everything else is denied.
//   - Documents can't be deleted except where the app legitimately deletes them.
//   - Basic shape validation on the financially sensitive writes.
// Upgrading to Firebase Auth (anonymous + custom claims) would allow real
// per-user enforcement; until then this limits blast radius, not identity.

service cloud.firestore {
  match /databases/{database}/documents {

    function isKnownUser(id) {
      return id in ['user1', 'user2', 'user3', 'user4'];
    }

    // Users: game state + push tokens + pin hash. No deletes.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isKnownUser(userId);
      allow delete: if false;
    }

    // Workouts: created by the logger, edited within the 24h window,
    // deleted only via the flag&vote flow.
    match /workouts/{workoutId} {
      allow read: if true;
      allow create: if isKnownUser(request.resource.data.userId)
        && request.resource.data.weekId is string
        && request.resource.data.date is string
        && request.resource.data.duration is number
        && request.resource.data.duration > 0
        && request.resource.data.duration <= 300;
      allow update: if request.resource.data.userId == resource.data.userId
        && request.resource.data.weekId == resource.data.weekId
        && request.resource.data.date == resource.data.date
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
          ['duration', 'calories', 'description', 'exerciseType', 'comments', 'reactions']
        );
      allow delete: if true; // flag&vote resolution deletes fake workouts
    }

    // Weekly summaries: written by the week-end close (client or Cloud Function).
    match /weekly_summaries/{summaryId} {
      allow read: if true;
      allow create, update: if isKnownUser(request.resource.data.userId);
      allow delete: if false;
    }

    // Absences (frozen weeks): managed in the Absence Planner.
    match /absences/{absenceId} {
      allow read: if true;
      allow create: if isKnownUser(request.resource.data.userId);
      allow update: if true;
      allow delete: if true; // planner allows removing a planned absence
    }

    // Justifications: created by the owner, votes update the votes map.
    match /justifications/{justificationId} {
      allow read: if true;
      allow create: if isKnownUser(request.resource.data.userId);
      allow update: if true;
      allow delete: if false;
    }

    // Flagged workouts (flag & vote).
    match /flagged_workouts/{workoutId} {
      allow read: if true;
      allow create: if isKnownUser(request.resource.data.flaggedBy);
      allow update: if true;
      allow delete: if false;
    }

    // Achievement unlocks (feed items).
    match /achievement_unlocks/{unlockId} {
      allow read: if true;
      allow create: if isKnownUser(request.resource.data.userId);
      allow update, delete: if false;
    }

    // AI recaps: generated by Cloud Functions (admin SDK bypasses rules).
    match /weekly_recaps/{weekId} {
      allow read: if true;
      allow write: if false;
    }
    match /monthly_recaps/{monthId} {
      allow read: if true;
      allow write: if false;
    }

    // App meta: the week-end processing lock lives here.
    match /settings/{docId} {
      allow read: if true;
      allow write: if docId == 'meta';
    }

    // Everything else: denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
